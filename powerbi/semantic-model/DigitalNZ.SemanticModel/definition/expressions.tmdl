expression RecordsCsvPath = "exports/frictionless/records.csv"
    description: Frictionless records CSV path, relative to the repo root.

expression CitationsCsvPath = "exports/frictionless/citations.csv"
    description: Citation export CSV path, relative to the repo root.

expression VectorClustersCsvPath = "exports/frictionless/vector_clusters.csv"
    description: Vector cluster export CSV path, relative to the repo root.

expression LoadCsv =
    (path as text) as table =>
        let
            Source = Csv.Document(
                File.Contents(path),
                [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]
            ),
            PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars = true])
        in
            PromotedHeaders

